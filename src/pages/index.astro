---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { ANNOUNCEMENT, AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// 最近文章（按时间倒序，取前 4 篇）
const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.intro {
				margin-bottom: 2.5em;
			}
			.intro h1 {
				margin-bottom: 0.3em;
			}
			.intro .subtitle {
				color: rgb(var(--gray));
				font-size: 1.2em;
				margin-bottom: 1em;
			}
			.intro p {
				margin-bottom: 0.8em;
			}
			.section-title {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				border-bottom: 2px solid rgb(var(--gray-light));
				padding-bottom: 0.3em;
				margin-bottom: 1em;
			}
			.section-title h2 {
				margin: 0;
				font-size: 1.5em;
			}
			.section-title a {
				font-size: 0.9em;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				padding: 0.8em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post-list .title {
				display: block;
				font-size: 1.15em;
				font-weight: 600;
				line-height: 1.3;
			}
			.post-list .date {
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin-top: 0.2em;
			}
			.post-list .excerpt {
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
				margin-top: 0.3em;
				line-height: 1.5;
			}
			.post-list a:hover .title {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{AUTHOR}</h1>
				<p class="subtitle">{SITE_DESCRIPTION}</p>
				<p>{ANNOUNCEMENT}</p>
				<p>
					深耕 AI / 深度学习方向，关注大模型后训练、GRPO、归一化、多智能体工作流等话题。崇尚独立探索，注重基础，知其然也知其所以然。
				</p>
			</section>

			<section>
				<div class="section-title">
					<h2>最近文章</h2>
					<a href="/blog">查看全部 →</a>
				</div>
				<ul class="post-list">
					{
						recentPosts.map((post) => (
							<li>
								<a href={`/${post.data.slug}/`}>
									<span class="title">{post.data.title}</span>
									<div class="date">
										<FormattedDate date={post.data.pubDate} />
									</div>
									{post.data.description && (
										<div class="excerpt">{post.data.description}</div>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
