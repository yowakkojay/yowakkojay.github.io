---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import Giscus from "@/components/Giscus.astro";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
	}}
>
	<article class="grow break-words" data-pagefind-body>
		<div id="reading-progress" class="bg-accent fixed start-0 top-0 z-50 h-0.5" style="width: 0%"></div>
		<div id="blog-hero" class="mb-12"><Masthead content={post} readingTime={readingTime} /></div>
		<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
			{!!headings.length && <TOC headings={headings} />}
			<div
				class="prose prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-muted prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none"
			>
					<slot />
					<WebMentions />
					<Giscus />
			</div>
		</div>
	</article>
	<!-- 图片灯箱：点击正文图片放大查看，点击图片外 / X / ESC 关闭 -->
	<div
		aria-modal="true"
		class="fixed inset-0 z-100 flex cursor-zoom-out items-center justify-center bg-black/80 p-4"
		id="lightbox"
		role="dialog"
	>
		<button
			aria-label="关闭大图"
			class="absolute end-4 top-4 cursor-pointer rounded-full bg-white/10 p-2 text-white hover:bg-white/25"
			id="lightbox-close"
			type="button"
		>
			<svg
				aria-hidden="true"
				class="h-6 w-6"
				fill="none"
				stroke="currentColor"
				stroke-linecap="round"
				stroke-width="2"
				viewBox="0 0 24 24"
			>
				<path d="M6 6l12 12M18 6L6 18" />
			</svg>
		</button>
		<img alt="" class="max-h-[90vh] max-w-full cursor-default object-contain" id="lightbox-img" src="" />
	</div>
	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<style>
	#lightbox {
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.2s ease,
			visibility 0.2s;
	}
	#lightbox.open {
		opacity: 1;
		visibility: visible;
	}
	#lightbox img {
		transform: scale(0.96);
		transition: transform 0.2s ease;
	}
	#lightbox.open img {
		transform: scale(1);
	}
</style>

<script>
	// ClientRouter 下模块脚本只执行一次，因此初始化逻辑改为响应 astro:page-load，
	// 每次进入文章页重新绑定；并在重新绑定前清理上一页的 document 级监听器，避免累积。
	let headerObserver: IntersectionObserver | null = null;
	let onScroll: (() => void) | null = null;
	let onKeydown: ((e: KeyboardEvent) => void) | null = null;

	document.addEventListener("astro:page-load", () => {
		// 清理上一篇文章页注册的 document 级监听器与观察器
		headerObserver?.disconnect();
		if (onScroll) document.removeEventListener("scroll", onScroll);
		if (onKeydown) document.removeEventListener("keydown", onKeydown);
		headerObserver = null;
		onScroll = null;
		onKeydown = null;

		const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
		const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;
		const progressBar = document.getElementById("reading-progress") as HTMLDivElement;
		const lightbox = document.getElementById("lightbox") as HTMLDivElement;
		const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
		// 非文章页没有这些元素，直接跳过
		if (!scrollBtn || !targetHeader || !progressBar || !lightbox || !lightboxImg) return;

		function callback(entries: IntersectionObserverEntry[]) {
			entries.forEach((entry) => {
				// only show the scroll to top button when the heading is out of view
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		}

		scrollBtn.addEventListener("click", () => {
			document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
		});

		headerObserver = new IntersectionObserver(callback);
		headerObserver.observe(targetHeader);

		// 顶部阅读进度条
		function updateProgress() {
			const root = document.documentElement;
			const max = root.scrollHeight - root.clientHeight;
			progressBar.style.width = `${max > 0 ? (root.scrollTop / max) * 100 : 0}%`;
		}
		onScroll = updateProgress;
		document.addEventListener("scroll", onScroll, { passive: true });
		updateProgress();

		// 图片灯箱：点击正文图片放大，点击图片外 / X / ESC 关闭
		function closeLightbox() {
			lightbox.classList.remove("open");
			document.body.style.overflow = "";
		}
		document.querySelectorAll<HTMLImageElement>(".prose img").forEach((img) => {
			if (img.closest("a")) return; // 跳过链接里的图（如 wandb 徽章），保留跳转行为
			img.style.cursor = "zoom-in";
			img.addEventListener("click", () => {
				lightboxImg.src = img.currentSrc || img.src;
				lightboxImg.alt = img.alt;
				lightbox.classList.add("open");
				document.body.style.overflow = "hidden";
			});
		});
		// X 按钮也在遮罩内，点击图片之外的任何位置都会触发关闭
		lightbox.addEventListener("click", (e) => {
			if (e.target !== lightboxImg) closeLightbox();
		});
		onKeydown = (e) => {
			if (e.key === "Escape" && lightbox.classList.contains("open")) closeLightbox();
		};
		document.addEventListener("keydown", onKeydown);
	});
</script>
